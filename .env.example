# Generated from all registered verifier configuration domains. Do not add unregistered variables.
# Copy required local values to .env; never commit .env.

# verifier 使用的 Python 解释器或可执行命令
# type=string; required=false; secret=false; bind=python.executable
PYTHON_EXECUTABLE=

# verifier server 监听地址
# type=string; required=false; secret=false; bind=server.host
VERIFIER_HOST=

# verifier server 监听端口
# type=integer; required=false; secret=false; bind=server.port
VERIFIER_PORT=

# verifier UAT 服务监听地址
# type=string; required=false; secret=false; bind=uat.host
VERIFIER_UAT_HOST=

# verifier UAT 服务监听端口
# type=integer; required=false; secret=false; bind=uat.port
VERIFIER_UAT_PORT=

# Selenium checklist 使用的 ChromeDriver 可执行文件或命令
# type=path; required=false; secret=false; bind=browser.driver_path
CHROMEDRIVER_PATH=

# 临时覆盖公共 LLM provider
# type=string; required=false; secret=false; bind=llm.provider
LLM_PROVIDER=

# 临时覆盖公共 LLM model
# type=string; required=false; secret=false; bind=llm.model
LLM_MODEL=

# 临时覆盖公共 LLM base URL
# type=url; required=false; secret=false; bind=llm.base_url
LLM_BASE_URL=

# verifier 默认 DeepSeek API Key
# type=string; required=true; secret=true; bind=llm.api_key
DEEPSEEK_API_KEY=

# verifier 默认百炼 embedding API Key
# type=string; required=false; secret=true; bind=embedding.api_key
BAILIAN_API_KEY=

# 临时覆盖百炼 embedding model
# type=string; required=false; secret=false; bind=embedding.model
BAILIAN_EMBEDDING_MODEL=

# embedding HTTP 会话是否继承系统代理
# type=boolean; required=false; secret=false; bind=embedding.trust_env_proxy
BAILIAN_EMBEDDING_TRUST_ENV_PROXY=

# Context runtime 数据目录
# type=path; required=false; secret=false; bind=context.data_root
CONTEXT_DATA_ROOT=

# LLM context 记录存储目录
# type=path; required=false; secret=false; bind=context.store_root
CONTEXT_STORE_ROOT=

# 客户搜索业务源码挂载位置
# type=path; required=false; secret=false; bind=project.resources.source.repository
CLIENT_SEARCH_REPO=

# 客户搜索解析服务地址
# type=url; required=false; secret=false; bind=runtime.services.primary.base_url
CLIENT_SEARCH_BASE_URL=

# 下游客户搜索服务地址
# type=url; required=false; secret=false; bind=runtime.services.dependencies.downstream_search.base_url
CLIENT_SEARCH_DOWNSTREAM_BASE_URL=

# deer-flow 业务源码挂载位置及本地启动根目录
# type=path; required=true; secret=false; bind=project.resources.source.repository
DEERFLOW_REPO=

# deer-flow Gateway 服务地址
# type=url; required=false; secret=false; bind=runtime.services.primary.base_url
DEERFLOW_BASE_URL=

# 营销规划业务源码挂载位置
# type=path; required=false; secret=false; bind=project.resources.source.repository
MARKETTING_PLANNING_REPO=

# 营销规划服务地址
# type=url; required=false; secret=false; bind=runtime.services.primary.base_url
MARKETTING_PLANNING_BASE_URL=

# 营销规划业务源码挂载位置（意图识别项目）
# type=path; required=false; secret=false; bind=project.resources.source.repository
MARKETTING_PLANNING_INTENT_REPO=

# 营销规划意图识别服务地址
# type=url; required=false; secret=false; bind=runtime.services.primary.base_url
MARKETTING_PLANNING_INTENT_BASE_URL=
