{
  "permissions": {
    "allow": [
      "Bash(/Users/xiaozijian/miniconda3/envs/agno/bin/python3 -c *)",
      "Bash(git show *)",
      "Bash(.venv/bin/python3 -c *)",
      "Bash(.venv/bin/python3 *)",
      "Bash(tail -100 *)",
      "Bash(find *)",
      "Bash(python3 -c *)",
      "Bash(nohup /Users/xiaozijian/miniconda3/envs/agno/bin/python -m *)",
      "Bash(/Users/xiaozijian/miniconda3/envs/agno/bin/python -c *)",
      "Bash(python3 *)"
    ]
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/worktree_create.py",
            "timeout": 30
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/worktree_remove.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
